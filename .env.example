# MCP Server Environment Configuration

# Transport: stdio | sse
MCP_TRANSPORT=sse
MCP_PORT=8300

# Cloud Provider: aws | azure | local
CLOUD_PROVIDER=local

# Logging
LOG_LEVEL=info

# PostgreSQL (for database tools)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mcp_data
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_pass

# API Integration
PORTFOLIO_API_URL=http://localhost:8200

# Authentication (for SSE transport)
MCP_API_KEY=
MCP_RATE_LIMIT_RPM=60

# AWS (when CLOUD_PROVIDER=aws)
AWS_REGION=eu-west-1

# Azure (when CLOUD_PROVIDER=azure)
AZURE_RESOURCE_GROUP=rg-mcp-server
AZURE_LOCATION=westeurope

# =============================================================================
# Protocol-tuning labs
# See docs/hands-on-labs/hands-on-labs-config-tuning.md
# App code does not yet read these — wiring them up is part of running each lab.
# =============================================================================
MCP_SCHEMA_STRICT_MODE=true     # Strict JSON schema validation on tool inputs
MCP_ERROR_MODE=structured       # structured|verbose|silent
MCP_INPUT_VALIDATION_LEVEL=strict # strict|loose|off
